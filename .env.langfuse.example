# Self-hosted Langfuse dev env — copy to `.env.langfuse` (gitignored by .env.*).
#
# NEXTAUTH_SECRET + LANGFUSE_SALT must be STABLE across restarts — rotating them
# breaks every existing Langfuse user session and API key. Generate once:
#   openssl rand -hex 32
#
# Regenerating the SALT invalidates all project API keys stored in Vault, which
# forces a re-run of `docker compose --profile bootstrap run --rm langfuse-init`
# and a `scripts/seed_vault_dev.py` refresh.

NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
LANGFUSE_SALT=replace-with-openssl-rand-hex-32

# Deterministic dev bootstrap (bypasses the web-ui signup flow)
LANGFUSE_INIT_ORG_ID=aiflow-dev
LANGFUSE_INIT_ORG_NAME=AIFlow Dev
LANGFUSE_INIT_PROJECT_ID=aiflow-dev
LANGFUSE_INIT_PROJECT_NAME=AIFlow Dev
LANGFUSE_INIT_USER_EMAIL=admin@aiflow.dev
LANGFUSE_INIT_USER_NAME=AIFlow Admin
LANGFUSE_INIT_USER_PASSWORD=aiflow-dev-password

# Optional: pin the project keypair (recommended — keeps Vault in sync across restarts).
# Leave empty on first boot to let Langfuse generate, then copy the output of the
# langfuse-init container back here and restart `langfuse-web`.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
