# AIFlow Development Environment
# Copy to .env and fill in your values: cp .env.example .env

# === Database ===
AIFLOW_DATABASE__URL=postgresql+asyncpg://aiflow:aiflow_dev_password@localhost:5433/aiflow_dev

# === Redis ===
AIFLOW_REDIS__URL=redis://localhost:6379/0

# === Environment ===
AIFLOW_ENVIRONMENT=dev
AIFLOW_DEBUG=true
AIFLOW_LOG_LEVEL=DEBUG

# === LLM (at least one required) ===
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Langfuse (optional for dev, required for staging+) ===
# AIFLOW_LANGFUSE__PUBLIC_KEY=pk-lf-your-key    # legacy env alias; prefer Vault `langfuse#public_key`
# AIFLOW_LANGFUSE__SECRET_KEY=sk-lf-your-key    # legacy env alias; prefer Vault `langfuse#secret_key`
# AIFLOW_LANGFUSE__HOST=https://cloud.langfuse.com
# AIFLOW_LANGFUSE__ENABLED=true
#
# Self-hosted Langfuse (air-gapped) — bring up the stack first:
#   docker compose -f docker-compose.langfuse.yml --env-file .env.langfuse up -d
# then flip the host + enabled flag:
# AIFLOW_LANGFUSE__HOST=http://localhost:3000
# AIFLOW_LANGFUSE__ENABLED=true

# === Security (generate with: openssl genrsa -out jwt_private.pem 2048) ===
AIFLOW_SECURITY__JWT_PRIVATE_KEY_PATH=./jwt_private.pem
AIFLOW_SECURITY__JWT_PUBLIC_KEY_PATH=./jwt_public.pem
AIFLOW_SECURITY__API_KEY_PREFIX=aiflow_
